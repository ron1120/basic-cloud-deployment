pipeline {
    agent any

    options {
        buildDiscarder(logRotator(numToKeepStr: '10'))
        timeout(time: 1, unit: 'HOURS')
    }

    parameters {
        booleanParam(name: 'SKIP_TEST', defaultValue: false, description: 'Skip the Test stage')
        booleanParam(name: 'SKIP_PUSH', defaultValue: false, description: 'Skip the Push to DockerHub stage')
        booleanParam(name: 'TERRAFORM_DESTROY', defaultValue: false, description: 'Destroy AWS infrastructure after pipeline')
    }

    triggers { githubPush() }

    environment {
        PYTHON_VERSION = '3.8'
        GIT_CREDENTIALS = credentials('RonGitUser')
        REPO_URL = 'https://github.com/ron1120/basic-cloud-deployment.git'
        DISCORD_TOKEN = credentials('DISCORD_TOKEN')
        DOCKERHUB_CREDS = credentials('RonDockerUser')
        DOCKER_IMAGE = "ronsss/discord-bot"
    }

    stages {
        stage('Checkout') {
            steps {
                script {
                    git branch: 'main', credentialsId: env.GIT_CREDENTIALS, url: env.REPO_URL

                    env.GIT_BRANCH_NAME = sh(script: 'git rev-parse --abbrev-ref HEAD', returnStdout: true).trim()

                    if (env.GIT_BRANCH_NAME == 'main') {
                        echo "On main branch, proceeding with build and deploy."
                    } else {
                        error "Not on main branch, aborting pipeline."
                    }
                }
            }
        }

        stage('Test') {
            when {
                expression { return !params.SKIP_TEST }
            }
            steps {
                echo 'Building and testing bot...'
                sh 'docker build -t discord-bot ./discord-bot'
                sh 'docker run -d --name discord-bot-test -e DISCORD_TOKEN=$DISCORD_TOKEN_PSW discord-bot'
                sh 'sleep 10'
                sh 'docker logs discord-bot-test'
                script {
                    def running = sh(script: 'docker inspect -f {{.State.Running}} discord-bot-test', returnStdout: true).trim()
                    sh 'docker stop discord-bot-test'
                    sh 'docker rm discord-bot-test'
                    if (running != 'true') {
                        error 'Bot failed to stay running. Check the logs above.'
                    }
                }
                echo 'Test passed, bot connected successfully.'
            }
        }

        stage('Push to DockerHub') {
            when {
                expression { return !params.SKIP_PUSH }
            }
            steps {
                echo 'Pushing image to DockerHub...'
                sh 'echo $DOCKERHUB_CREDS_PSW | docker login -u $DOCKERHUB_CREDS_USR --password-stdin'
                sh 'docker tag discord-bot $DOCKER_IMAGE:latest'
                sh 'docker tag discord-bot $DOCKER_IMAGE:${BUILD_NUMBER}'
                sh 'docker push $DOCKER_IMAGE:latest'
                sh 'docker push $DOCKER_IMAGE:${BUILD_NUMBER}'
                sh 'docker logout'
                echo "Pushed $DOCKER_IMAGE:latest and $DOCKER_IMAGE:${BUILD_NUMBER}"
            }
        }

        stage('Deploy') {

            steps {
                withCredentials([string(credentialsId: 'AWS_ACCESS_KEY_ID', variable: 'AWS_ACCESS_KEY_ID'),
                                 string(credentialsId: 'AWS_SECRET_ACCESS_KEY', variable: 'AWS_SECRET_ACCESS_KEY')]) {
                echo 'Provisioning infrastructure with Terraform...'
                dir('infastructure/terraform') {
                    sh 'terraform init -input=false'
                    sh 'terraform apply -auto-approve'
                    script {
                        env.EC2_IP = sh(script: 'terraform output -raw instance_public_ip', returnStdout: true).trim()
                    }
                }
                echo "EC2 instance ready at ${env.EC2_IP}"

                echo 'Waiting for EC2 to be reachable...'
                sh 'sleep 30'

                echo 'Deploying bot with Ansible...'
                dir('infastructure/ansible') {
                    sh """
                        echo '[app]' > inventory_dynamic.ini
                        echo '${env.EC2_IP}' >> inventory_dynamic.ini
                        echo '' >> inventory_dynamic.ini
                        echo '[app:vars]' >> inventory_dynamic.ini
                        echo 'ansible_user=ubuntu' >> inventory_dynamic.ini
                        echo 'ansible_ssh_private_key_file=/var/jenkins_home/.ssh/awsFE.pem' >> inventory_dynamic.ini
                        echo 'ansible_python_interpreter=/usr/bin/python3' >> inventory_dynamic.ini
                    """
                    sh 'cat inventory_dynamic.ini'
                    sh 'cat playbook.yml'
                    sh 'ANSIBLE_HOST_KEY_CHECKING=False ansible-playbook -i inventory_dynamic.ini playbook.yml --extra-vars "discord_token=$DISCORD_TOKEN_PSW docker_tag=${BUILD_NUMBER}"'
                }
                echo 'Bot deployed to production!'
                }
            }
        }

        stage('Teardown') {
            when {
                expression { return params.TERRAFORM_DESTROY }
            }
            steps {
                withCredentials([string(credentialsId: 'AWS_ACCESS_KEY_ID', variable: 'AWS_ACCESS_KEY_ID'),
                                 string(credentialsId: 'AWS_SECRET_ACCESS_KEY', variable: 'AWS_SECRET_ACCESS_KEY')]) {
                    echo 'Destroying AWS infrastructure...'
                    dir('infastructure/terraform') {
                        sh 'terraform init -input=false'
                        sh 'terraform destroy -auto-approve'
                    }
                    echo 'Infrastructure destroyed.'
                }
            }
        }
    }

    post {
        success {
            echo 'Pipeline completed successfully.'
        }
        failure {
            echo 'Pipeline failed.'
            node('') {
                sh 'docker stop discord-bot-test || true'
                sh 'docker rm discord-bot-test || true'
            }
        }
        always {
            node('') {
                sh 'docker image prune -f || true'
            }
            cleanWs()
        }
    }
}
