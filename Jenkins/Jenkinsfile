pipeline {
    agent any

    options {
        buildDiscarder(logRotator(numToKeepStr: '10'))
        timeout(time: 1, unit: 'HOURS')
    }

    triggers { githubPush() }

    environment {
        PYTHON_VERSION = '3.8'
        GIT_CREDENTIALS = credentials('RonGitUser')
        REPO_URL = 'https://github.com/ron1120/basic-cloud-deployment.git'
        DISCORD_TOKEN = credentials('DISCORD_TOKEN')

    }

    stages {
        stage('Checkout') {
            steps {
                script {
                    git branch: 'main', credentialsId: env.GIT_CREDENTIALS, url: env.REPO_URL

                    env.GIT_BRANCH_NAME = sh(script: 'git rev-parse --abbrev-ref HEAD', returnStdout: true).trim()

                    if (env.GIT_BRANCH_NAME == 'main') {
                        echo "On main branch, proceeding with build and deploy."
                    } else {
                        error "Not on main branch, aborting pipeline."
                    }
                }
            }
        }

        stage('Test') {
            steps {
                echo 'Testing...'
            }
        }

        stage('Deploy') {
            steps {
                echo 'Deploying...'
                sh '''
                    export PYTHON_DIR="$HOME/python3"
                    if [ ! -f "$PYTHON_DIR/bin/python3" ]; then
                        echo "Installing standalone Python..."
                        curl -sSL https://github.com/indygreg/python-build-standalone/releases/download/20240726/cpython-3.11.9+20240726-x86_64-unknown-linux-gnu-install_only.tar.gz -o /tmp/python.tar.gz
                        mkdir -p "$PYTHON_DIR"
                        tar -xzf /tmp/python.tar.gz -C "$PYTHON_DIR" --strip-components=1
                        rm /tmp/python.tar.gz
                    fi
                    export PATH="$PYTHON_DIR/bin:$PATH"
                    cd discord-bot
                    python3 -m pip install -r requirements.txt
                    nohup python3 bot.py &
                    sleep 5
                    echo "Deployment complete."
                '''
            }
        }
    }

    post {
        success {
            echo 'Pipeline completed successfully.'
        }
        failure {
            echo 'Pipeline failed.'
        }
    }
}
